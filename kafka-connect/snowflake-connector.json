{
  "name": "snowflake-sink-cdc",
  "config": {
    "connector.class": "com.snowflake.kafka.connector.SnowflakeSinkConnector",
    "tasks.max": "1",
    "topics": "cdc.public.iot_events",
    "snowflake.topic2table.map": "cdc.public.iot_events:IOT_EVENTS",
    "snowflake.url.name": "REPLACE_WITH_ACCOUNT.snowflakecomputing.com:443",
    "snowflake.user.name": "REPLACE_WITH_SNOWFLAKE_USER",
    "snowflake.private.key": "REPLACE_WITH_PRIVATE_KEY_FOR_KEYPAIR_AUTH",
    "snowflake.database.name": "HACKATHON_IOT",
    "snowflake.schema.name": "RAW",
    "buffer.count.records": "1000",
    "buffer.flush.time": "60",
    "buffer.size.bytes": "5000000",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}
